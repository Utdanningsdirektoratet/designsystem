{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json", "eslint.config.js"],
  "futureFlags": {
    "affectedUsingTaskInputs": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^inject"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "inject": {
      "cache": false
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "dev": {
      "persistent": true,
      "dependsOn": ["build"]
    }
  }
}
