{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "release": {
    "projectsRelationship": "fixed",
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github",
        "renderer": "{workspaceRoot}/changelog-renderer.ts",
        "renderOptions": {
          "authors": false
        }
      }
    },
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk"
    }
  }
}
