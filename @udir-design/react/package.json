  "scripts": {
    "generate:exports": "../../@internal/build-tools/bin/generate-react-exports.ts",
    "prebuild": "pnpm generate:exports",
    "predev": "pnpm generate:exports",
    "build": "vite build",
    "inject": "echo 'Dummy script to trigger pnpm injected dependency sync'",
    "lint:cycles": "pnpm madge --circular ./src/alpha.ts",
    "typecheck": "tsgo --build",
    "dev": "storybook dev --port 6005",
    "build:storybook": "storybook build --stats-json",
    "build:docs": "typedoc",
    "watch:typedoc": "typedoc --watch --tsconfig tsconfig.lib.json",
    "serve:typedoc": "pnpm dlx http-server --port=8090 -c-1 ./storybook-static/typedoc",
    "serve:docs": "pnpm dlx http-server ./storybook-static",
    "pretest": "pnpm pretest:storybook",
    "test": "vitest --outputFile.json test-reports/all.json",
    "test:unit": "vitest --project unit --outputFile.json test-reports/unit.json",
    "pretest:storybook": "pnpm exec playwright install --with-deps chromium",
    "test:storybook": "vitest --project storybook --outputFile.json test-reports/storybook.json --outputFile.html test-reports/storybook/index.html",
    "view-test-report:storybook": "pnpm dlx http-server ./test-reports/storybook"
  },
