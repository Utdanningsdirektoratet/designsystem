            <div data-hide>
              <h3
                data-size="xs"
                style="<removed>"
              >
                Overskrift 2
              </h3>
              <ul>
                <li>
                  <a href>
                    Link 1
                  </a>
                </li>
                <li>
                  <a href>
                    Link 2
                  </a>
                </li>
                <li>
                  <a href>
                    Link 3
                  </a>
                </li>
                <li>
