exports[`Udir No 1`] = `
<div data-size="auto">
  <style>
    /* Styles defined in application-specific css */
  .udirNo-header-menu-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--ds-size-10) var(--ds-size-15);
    gap: var(--ds-size-4);
    row-gap: var(--ds-size-10);
  }
  </style>
  <header
    data-scroll-direction="up"
    data-top="true"
    style="--udsc-header-max-width: 80rem;"
  >
    <div>
      <a href="https://www.udir.no/">
        <div style="--uds-logo-padding: 0;">
          <img
            alt="Utdanningsdirektoratet"
            src="/assets/img/udir-main-logo.svg"
          >
          <img
            alt="Utdanningsdirektoratet"
            src="/assets/img/udir-main-logo-dark-mode.svg"
          >
        </div>
      </a>
      <div>
        <div
          data-show="sm"
          style="max-width: 280px;"
        >
          <input
            aria-label="Søk"
            placeholder="Søk"
            type="search"
          >
          <button
            aria-label="Tøm"
            data-icon="true"
            data-variant="tertiary"
            type="reset"
          >
          </button>
        </div>
