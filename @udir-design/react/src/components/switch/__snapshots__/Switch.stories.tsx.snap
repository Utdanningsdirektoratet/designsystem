exports[`Group 1`] = `
<fieldset>
  <legend
    id="components-switch--grouplegend"
    data-weight="medium"
  >
    Varsler
  </legend>
  <ds-field>
    <input
      role="switch"
      id="components-switch--grouplydvarsler"
      type="checkbox"
      value="lydvarsler"
      checked
    >
    <label data-weight="regular">
      Lydvarsler
    </label>
    <div data-field="description">
      Spill av lyd når et varsel mottas.
    </div>
  </ds-field>
  <ds-field>
    <input
      role="switch"
      id="components-switch--grouppopup-varsler"
      type="checkbox"
      value="popup-varsler"
    >
    <label data-weight="regular">
      Popup-varsler
    </label>
    <div data-field="description">
      Vis popup-varsler på skjermen.
    </div>
  </ds-field>
  <ds-field>
    <input
      role="switch"
      id="components-switch--groupemail-varsler"
      type="checkbox"
      value="email-varsler"
    >
    <label data-weight="regular">
      E-postvarsler
    </label>
    <div data-field="description">
      Tillat e-postvarsler for viktige oppdateringer.
    </div>
  </ds-field>
</fieldset>
`;

