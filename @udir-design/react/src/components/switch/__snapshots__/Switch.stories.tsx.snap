exports[`Checked 1`] = `
<ds-field data-clickdelegatefor="components-switch--checked">
  <input
    role="switch"
    id="components-switch--checked"
    type="checkbox"
    checked
  >
  <label
    data-weight="regular"
    for="components-switch--checked"
  >
    En bryter
  </label>
</ds-field>
`;

exports[`Controlled 1`] = `
<fieldset>
  <legend
    id="components-switch--controlledlegend"
    data-weight="medium"
  >
    <h2>
      Innstillinger
    </h2>
  </legend>
  <ds-field>
    <input
      role="switch"
      id="components-switch--controlled"
      type="checkbox"
      checked
    >
    <label data-weight="regular">
      Varsler
    </label>
  </ds-field>
  <p
    data-variant="default"
    id="components-switch--controlleddescription"
  >
    Velg hvilke typer varsler du ønsker å motta.
  </p>
  <ds-field>
    <input
      id="components-switch--controlledlydvarsler"
      type="checkbox"
    >
    <label data-weight="regular">
      Lydvarsler
    </label>
  </ds-field>
  <ds-field>
    <input
      id="components-switch--controlledepostvarsler"
      type="checkbox"
      checked
    >
    <label data-weight="regular">
      Epostvarsler
    </label>
  </ds-field>
  <ds-field>
    <input
      id="components-switch--controlledpopupvarsler"
      type="checkbox"
    >
    <label data-weight="regular">
      Popup-varsler
    </label>
  </ds-field>
</fieldset>
`;

