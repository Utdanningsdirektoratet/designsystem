exports[`With Textfield 1`] = `
<fieldset aria-labelledby="mnsrx8q6pp74 mnsrx8q6pp75">
  <legend
    data-weight="medium"
    id="mnsrx8q6pp74"
  >
    <h2 data-size="sm">
      Adresse
    </h2>
  </legend>
  <p
    data-variant="default"
    id="mnsrx8q6pp75"
  >
    Skriv inn adressen din for å motta post fra oss.
  </p>
  <ds-field>
    <label
      data-weight="medium"
      for="components-fieldset--with-textfield-textfield"
    >
      Gateadresse
    </label>
    <div>
      <input
        id="components-fieldset--with-textfield-textfield"
        type="text"
        name="components-fieldset--with-textfield-textfield"
      >
    </div>
  </ds-field>
  <ds-field>
    <label
      data-weight="medium"
      for="components-fieldset--with-textfield-textfield"
    >
      Postnummer
    </label>
    <div>
      <input
        id="components-fieldset--with-textfield-textfield"
        pattern="[0-9]*"
        inputmode="numeric"
        size="4"
        type="text"
        name="components-fieldset--with-textfield-textfield"
      >
    </div>
  </ds-field>
  <ds-field>
    <label
      data-weight="medium"
      for="components-fieldset--with-textfield-textfield2"
    >
      Poststed
    </label>
    <div>
      <input
        id="components-fieldset--with-textfield-textfield2"
        size="25"
        type="text"
        name="components-fieldset--with-textfield-textfield2"
      >
    </div>
  </ds-field>
</fieldset>
`;
