// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Preview 1`] = `
<div data-size="auto">
  <style>
    .example-filters-section {
            display: flex;
                flex-direction: row;
                justify-content: space-between;
                align-items: flex-end;
                gap: var(--ds-size-6);
        }
        .example-suggestion-section {
            display: flex;
            flex-direction: row;
            gap: var(--ds-size-4);
            align-items: flex-end;
            width: auto;
        }
        .example-suggestion-field {
            max-width: 280px;
            width: auto;
        }
        .example-search-field {
            width: auto;
        }
        .example-main {
          margin: 20px;
          gap: 20px;
        }
        .example-controls {
          display: flex;
          flex-direction: row;
          justify-content: space-between;
          align-items: center;
          gap: var(--ds-size-4);
          margin: var(--ds-size-6) var(--ds-size-2); 
        }
        .example-controls-section {
          display: flex;
          flex-direction: row;
          justify-content: flex-start;
          align-items: center;
          width: auto;
          gap: var(--ds-size-6);
        }
        .example-controls-section-span {
          color: var(--ds-color-neutral-text-subtle);
        }
        .example-controls-section-dropdown {
          display: flex;
          align-items: center;
          gap: var(--ds-size-2);
        }
