          </button>
        </u-details>
      </div>
    </dialog>
  </div>
  <div
    data-size="md"
    data-color-scheme="auto"
  >
    <h1 data-size="md">
      Skoleundersøkelse
    </h1>
    <form>
      <h2 data-size="sm">
        Avslutning
      </h2>
      <div>
        <label
          data-weight="medium"
          for="addition"
        >
          Har du noe annet du ønsker å nevne?
        </label>
        <div>
          <textarea
            id="addition"
            rows="4"
            name="addition"
          >
          </textarea>
        </div>
      </div>
      <fieldset
        id="contactMethods"
        tabindex="-1"
      >
        <legend data-weight="medium">
          Hvordan ønsker du at vi skal kontakte deg?
        </legend>
        <p data-variant="default">
          Velg ett eller flere alternativer
        </p>
        <div>
          <input
            id="contactMethodsEmail"
            aria-invalid="false"
            type="checkbox"
            value="epost"
            name="contactMethods"
          >
          <label
            data-weight="regular"
            for="contactMethodsEmail"
          >
            E-post
          </label>
        </div>
        <div>
          <input
            id="contactMethodsTelefon"
            aria-invalid="false"
            type="checkbox"
            value="telefon"
            name="contactMethods"
          >
          <label
            data-weight="regular"
            for="contactMethodsTelefon"
          >
            Telefon
          </label>
        </div>
        <div>
          <input
            id="contactMethodsSms"
            aria-invalid="false"
            type="checkbox"
            value="sms"
            name="contactMethods"
          >
          <label
            data-weight="regular"
            for="contactMethodsSms"
          >
            SMS
          </label>
        </div>
      </fieldset>
      <div>
        <button
          data-variant="secondary"
          type="button"
          style="flex: 1 1 0%;"
        >
          Forrige
        </button>
        <button
          data-variant="secondary"
          type="button"
          style="flex: 1 1 0%;"
        >
          Neste
        </button>
      </div>
      <dialog
        data-modal="true"
        closedby="closerequest"
        style="width: fit-content;"
      >
        <div>
          <h2 data-size="xs">
            Er du sikker på at du vil sende inn skjema?
          </h2>
          <div>
            <button
              data-variant="secondary"
              type="button"
              style="flex: 1 1 0%;"
            >
              Avbryt
            </button>
            <button
              data-variant="primary"
              type="submit"
              style="flex: 2 1 0%;"
            >
              Send inn
            </button>
          </div>
        </div>
      </dialog>
    </form>
  </div>
</div>
`;

