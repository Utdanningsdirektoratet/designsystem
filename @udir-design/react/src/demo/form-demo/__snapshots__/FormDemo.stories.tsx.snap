  </div>
  <div
    data-size="md"
    data-color-scheme="auto"
  >
    <h1 data-size="md">
      Skoleundersøkelse
    </h1>
    <form>
      <h2 data-size="sm">
        Personinformasjon
      </h2>
      <div>
        <label
          data-weight="medium"
          for="firstName"
        >
          Fornavn
        </label>
        <div>
          <input
            id="firstName"
            autocomplete="given-name"
            type="text"
            name="firstName"
          >
        </div>
      </div>
      <div>
        <label
          data-weight="medium"
          for="lastName"
        >
          Etternavn
        </label>
        <input
          id="lastName"
          autocomplete="family-name"
          aria-invalid="false"
          type="text"
          name="lastName"
        >
      </div>
      <div>
        <label
          data-weight="medium"
          for="county"
        >
          Fylke
        </label>
        <u-combobox>
          <input
            placeholder
            aria-invalid="false"
            id="county"
            type="text"
            data-label="Fylke"
            list=":u-datalist1"
            aria-label="Fylke​​​​​"
            popovertarget=":u-datalist1"
            aria-autocomplete="list"
            aria-controls=":u-datalist1"
            aria-expanded="true"
            autocomplete="off"
            role="combobox"
          >
          <del
            data-icon="true"
            data-variant="tertiary"
            aria-label="Tøm"
            hidden
            role="button"
          >
          </del>
          <u-datalist
            data-nofilter
            data-sr-singular="%d forslag"
            data-sr-plural="%d forslag"
            popover="manual"
            hidden
            role="listbox"
            tabindex="-1"
            aria-multiselectable="false"
            id=":u-datalist1"
            style="width: 592px; translate: <removed>;"
          >
            <u-option
              label="Oslo"
              value="Oslo"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Oslo
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Viken"
              value="Viken"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Viken
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Innlandet"
              value="Innlandet"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Innlandet
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Vestfold og Telemark"
              value="Vestfold og Telemark"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Vestfold og Telemark
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Agder"
              value="Agder"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Agder
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Rogaland"
              value="Rogaland"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Rogaland
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Vestland"
              value="Vestland"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Vestland
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Møre og Romsdal"
              value="Møre og Romsdal"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Møre og Romsdal
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Trøndelag"
              value="Trøndelag"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Trøndelag
              <div>
                Fylke
              </div>
            </u-option>
            <u-option
              label="Nordland"
              value="Nordland"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
