              </div>
            </u-option>
            <u-option
              label="Troms og Finnmark"
              value="Troms og Finnmark"
              tabindex="-1"
              role="option"
              aria-disabled="false"
              aria-selected="false"
            >
              Troms og Finnmark
              <div>
                Fylke
              </div>
