  <div
    data-size="md"
    data-color-scheme="auto"
  >
    <h1 data-size="md">
      Skoleundersøkelse
    </h1>
    <form>
      <h2>
        Innsending
      </h2>
      <p data-variant="default">
        Send inn skjema til Udir.
      </p>
      <div>
        <button
          data-variant="secondary"
          type="button"
          style="flex: 1 1 0%;"
        >
          Forrige
        </button>
        <button
          data-variant="primary"
          type="button"
          style="flex: 2 1 0%;"
        >
          Send inn skjema
        </button>
      </div>
      <dialog
        data-modal="true"
        closedby="closerequest"
        style="width: fit-content;"
      >
        <div>
          <h2 data-size="xs">
            Er du sikker på at du vil sende inn skjema?
          </h2>
          <div>
            <button
              data-variant="secondary"
              type="button"
              style="flex: 1 1 0%;"
            >
              Avbryt
            </button>
            <button
              data-variant="primary"
              type="submit"
              style="flex: 2 1 0%;"
            >
              Send inn
            </button>
          </div>
        </div>
      </dialog>
    </form>
  </div>
</div>
`;

