                  >
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </fieldset>
      <div>
        <button
          data-variant="secondary"
          type="button"
          style="flex: 1 1 0%;"
        >
          Forrige
        </button>
        <button
          data-variant="secondary"
          type="button"
          style="flex: 1 1 0%;"
        >
