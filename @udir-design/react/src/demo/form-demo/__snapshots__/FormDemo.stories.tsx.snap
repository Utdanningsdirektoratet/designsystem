          </u-datalist>
          <select
            name="county"
            hidden
            id="_r_1b_"
          >
          </select>
        </u-combobox>
      </div>
      <fieldset
        id="educationLevel"
        tabindex="-1"
      >
        <legend data-weight="medium">
          Utdanningsnivå
        </legend>
        <div>
          <input
            id="radio-kindergarten"
            type="radio"
            value="kindergarten"
            name="educationLevel"
          >
          <label
            data-weight="regular"
            for="radio-kindergarten"
          >
            Barnehage
          </label>
        </div>
        <div>
          <input
            id="radio-primary"
            type="radio"
            value="primary"
            name="educationLevel"
          >
          <label
            data-weight="regular"
            for="radio-primary"
          >
            Grunnskole
          </label>
        </div>
        <div>
          <input
            id="radio-secondary"
            type="radio"
            value="secondary"
            name="educationLevel"
          >
          <label
            data-weight="regular"
            for="radio-secondary"
          >
            Videregående
          </label>
        </div>
        <div>
          <input
            id="radio-higher"
            type="radio"
            value="higher"
            name="educationLevel"
          >
          <label
            data-weight="regular"
            for="radio-higher"
          >
            Høyere utdanning
          </label>
        </div>
      </fieldset>
      <div>
        <label
          data-weight="medium"
          for="ageGroup"
        >
          Aldersgruppe
        </label>
        <select
          id="ageGroup"
          aria-label="Velg aldersgruppe"
          name="ageGroup"
          aria-invalid="false"
        >
          <option
            value="blank"
            disabled
            selected
          >
            Velg aldersgruppe
          </option>
          <option value="kindergarten">
            3-5 år
          </option>
          <option value="kids">
            6-12 år
          </option>
          <option value="youth">
            13-20 år
          </option>
          <option value="adult">
            21 år og eldre
          </option>
        </select>
      </div>
      <div>
        <button
          data-variant="secondary"
          type="button"
          style="flex: 1 1 0%;"
        >
          Neste
        </button>
      </div>
      <dialog
        data-modal="true"
        closedby="closerequest"
        style="width: fit-content;"
      >
        <div>
          <h2 data-size="xs">
            Er du sikker på at du vil sende inn skjema?
          </h2>
          <div>
            <button
              data-variant="secondary"
              type="button"
              style="flex: 1 1 0%;"
            >
              Avbryt
            </button>
            <button
              data-variant="primary"
              type="submit"
              style="flex: 2 1 0%;"
            >
              Send inn
            </button>
          </div>
        </div>
      </dialog>
    </form>
  </div>
</div>
`;
