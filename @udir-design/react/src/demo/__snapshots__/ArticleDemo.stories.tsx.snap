              </a>
            </div>
            <hr
              aria-hidden="true"
              style="margin: var(--ds-size-4) 0;"
            >
          </div>
          <div
            data-variant="tinted"
            data-color="accent"
          >
            <u-details
              open
              data-variant="default"
              role="group"
            >
              <u-summary
                aria-expanded="true"
                role="button"
                slot="summary"
                tabindex="0"
              >
                Innhold på denne siden
              </u-summary>
              <div>
                <ol>
                  <li>
                    <a href="#follow-development">
                      <svg
