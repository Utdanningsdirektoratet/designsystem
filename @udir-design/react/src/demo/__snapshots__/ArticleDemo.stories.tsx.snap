              src="/assets/img/udir-main-logo.svg"
            >
            <img
              alt="Utdanningsdirektoratet"
              src="/assets/img/udir-main-logo-dark-mode.svg"
            >
          </div>
        </a>
      </div>
    </footer>
    <div aria-hidden="true">
      Dette er en demo
    </div>
  </div>
</div>
`;
