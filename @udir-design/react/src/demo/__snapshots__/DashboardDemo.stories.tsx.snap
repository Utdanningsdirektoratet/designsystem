              data-variant="tinted"
              data-color="support1"
            >
              <h2>
                Varsler
              </h2>
              <ds-field data-clickdelegatefor="sound-notifications">
                <input
                  role="switch"
                  id="sound-notifications"
                  type="checkbox"
                  value="sound-notifications"
                  aria-describedby="mmexwnxybcw14"
                >
                <label
                  data-weight="regular"
                  for="sound-notifications"
                >
                  Lydvarsler
                </label>
                <div
                  data-field="description"
                  id="mmexwnxybcw14"
                >
                  Spill av lyd når et varsel mottas.
                </div>
              </ds-field>
              <ds-field data-clickdelegatefor="popup-notifications">
                <input
                  role="switch"
                  id="popup-notifications"
                  type="checkbox"
                  value="popup-notifications"
                  aria-describedby="mmexwnxybcw15"
                >
                <label
                  data-weight="regular"
                  for="popup-notifications"
                >
                  Popup-varsler
                </label>
                <div
                  data-field="description"
                  id="mmexwnxybcw15"
                >
                  Vis popup-varsler på skjermen.
                </div>
              </ds-field>
              <ds-field data-clickdelegatefor="email-notifications">
                <input
                  role="switch"
                  id="email-notifications"
                  type="checkbox"
                  value="email-notifications"
                  aria-describedby="mmexwnxybcw16"
                >
                <label
                  data-weight="regular"
                  for="email-notifications"
                >
                  E-postvarsler
                </label>
                <div
                  data-field="description"
                  id="mmexwnxybcw16"
                >
                  Tillat e-postvarsler for viktige oppdateringer.
                </div>
              </ds-field>
            </div>
          </div>
        </div>
      </div>
    </ds-tabpanel>
  </ds-tabs>
</div>
