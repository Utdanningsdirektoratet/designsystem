                </legend>
                <p
                  data-variant="default"
                  id="mmexwnxybcw26"
                >
                  Velg hvem som har tilgang til å se profilen din.
                </p>
                <ds-field data-clickdelegatefor="privacy-public">
                  <input
                    id="privacy-public"
                    type="radio"
                    value="public"
                    checked
                    name="privacy"
                  >
                  <label
                    data-weight="regular"
                    for="privacy-public"
                  >
                    Alle
                  </label>
                </ds-field>
                <ds-field data-clickdelegatefor="privacy-friends">
                  <input
                    id="privacy-friends"
                    type="radio"
                    value="friends"
                    name="privacy"
                    aria-describedby="mmexwnxybcw29"
                  >
                  <label
                    data-weight="regular"
                    for="privacy-friends"
                  >
                    Kun venner
                  </label>
                  <div
                    data-field="description"
                    id="mmexwnxybcw29"
                  >
                    Bare personer du har lagt til kan se profilen din.
                  </div>
                </ds-field>
                <ds-field data-clickdelegatefor="privacy-private">
                  <input
                    id="privacy-private"
                    type="radio"
                    value="private"
                    name="privacy"
                  >
                  <label
                    data-weight="regular"
                    for="privacy-private"
                  >
                    Kun meg
                  </label>
                </ds-field>
                <p
                  data-field="validation"
                  hidden
                  id="validation-privacy"
                >
                </p>
              </fieldset>
            </div>
            <div
              data-variant="tinted"
              data-color="support1"
            >
              <h2>
                Varsler
              </h2>
              <ds-field data-clickdelegatefor="sound-notifications">
                <input
                  role="switch"
                  id="sound-notifications"
                  type="checkbox"
                  value="sound-notifications"
                  aria-describedby="mmexwnxybcw30"
                >
                <label
                  data-weight="regular"
                  for="sound-notifications"
                >
                  Lydvarsler
                </label>
                <div
                  data-field="description"
                  id="mmexwnxybcw30"
                >
                  Spill av lyd når et varsel mottas.
                </div>
              </ds-field>
              <ds-field data-clickdelegatefor="popup-notifications">
                <input
                  role="switch"
                  id="popup-notifications"
                  type="checkbox"
                  value="popup-notifications"
                  aria-describedby="mmexwnxybcw31"
                >
                <label
                  data-weight="regular"
                  for="popup-notifications"
                >
                  Popup-varsler
                </label>
                <div
                  data-field="description"
                  id="mmexwnxybcw31"
                >
                  Vis popup-varsler på skjermen.
                </div>
              </ds-field>
              <ds-field data-clickdelegatefor="email-notifications">
                <input
                  role="switch"
                  id="email-notifications"
                  type="checkbox"
                  value="email-notifications"
                  aria-describedby="mmexwnxybcw32"
                >
                <label
                  data-weight="regular"
                  for="email-notifications"
                >
                  E-postvarsler
                </label>
                <div
                  data-field="description"
                  id="mmexwnxybcw32"
                >
                  Tillat e-postvarsler for viktige oppdateringer.
                </div>
              </ds-field>
            </div>
          </div>
        </div>
      </div>
    </ds-tabpanel>
  </ds-tabs>
</div>
`;

