{
  "name": "@udir-design/symbols",
  "version": "0.0.0-semantically-released",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "github:Utdanningsdirektoratet/designsystem",
    "directory": "packages/@udir-design/symbols"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./metadata": {
      "import": {
        "types": "./dist/metadata.d.ts",
        "default": "./dist/metadata.mjs"
      },
      "require": {
        "types": "./dist/metadata.d.ts",
        "default": "./dist/metadata.cjs"
      }
    },
    "./svg/*.svg": "./dist/svg/*.svg",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "svgr symbols --typescript --ext tsx --no-prettier --index-template config/index-template.js --out-dir src && prettier --write ./src",
    "copy-util": "shx mkdir -p src/util && shx cp -r util/* src/util || exit 0",
    "parse-svg": "node config/parse-svg.js",
    "update-metadata": "node config/metadata.js",
    "copy-svgs": "shx mkdir -p dist/svg && shx cp -r symbols/*.svg dist/svg || exit 0",
    "prebuild": "pnpm run copy-util && pnpm run generate",
    "build": "tsup src/index.tsx --format esm,cjs --dts --sourcemap --clean --external react",
    "postbuild": "pnpm run update-metadata && pnpm run parse-svg",
    "fetch-new:symbols": "tsx config/figma/index.ts",
    "generate-pngs": "node config/svg-to-png.js"
  },
  "devDependencies": {
    "@figma/rest-api-spec": "^0.34.0",
    "@svgr/cli": "8.1.0",
    "@types/react": "^18.3.0",
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21",
    "prettier": "^3.3.0",
    "sharp": "^0.34.4",
    "shx": "^0.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
