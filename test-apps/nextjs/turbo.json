{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "persistent": true,
      "dependsOn": ["^build", "^inject"]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    }
  }
}
